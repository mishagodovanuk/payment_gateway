# Copy to .env and set REAL paths. Placeholders like /absolute/path/... will always fail.
#
# BadSSL demo (https://badssl.com/download/): ONE file contains cert + encrypted key.
# Run: bash scripts/fetch-badssl-certs.sh — then point BOTH vars at the same .pem file:
#
# MTLS_CLIENT_CERT=/var/www/payment_gateway/var/certs/badssl.com-client.pem
# MTLS_CLIENT_KEY=/var/www/payment_gateway/var/certs/badssl.com-client.pem
#
# Or use two separate PEMs from your real gateway — cert file + key file.

MTLS_CLIENT_CERT=/path/to/your-client.pem
MTLS_CLIENT_KEY=/path/to/your-client.pem
MTLS_CLIENT_KEY_PASSPHRASE=badssl.com

# Leave empty to use system CA bundle; or path to custom CA PEM
MTLS_CA_BUNDLE=

# true = verify server certificate (recommended). false only for local debugging.
MTLS_VERIFY_SSL=true

HMAC_SECRET=your-shared-secret

# Header used to send the hex HMAC (set to Authorization if your gateway expects it)
SIGNATURE_HEADER_NAME=X-Signature

# hash_hmac algorithm name (e.g. sha256, sha512)
SIGNATURE_HASH_ALGO=sha256
