{
    "name": "mishagodovanuk/payment_gateway",
    "description": "Framework-agnostic mTLS HTTP client with HMAC-signed GET requests for payment gateway integrations",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "payment",
        "mtls",
        "hmac",
        "guzzle",
        "tls",
        "client-certificate"
    ],
    "homepage": "https://github.com/mishagodovanuk/payment_gateway",
    "support": {
        "issues": "https://github.com/mishagodovanuk/payment_gateway/issues",
        "source": "https://github.com/mishagodovanuk/payment_gateway"
    },
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-openssl": "*",
        "guzzlehttp/guzzle": "^7.8",
        "guzzlehttp/psr7": "^2.6",
        "psr/http-message": "^2.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpmd/phpmd": "^2.15",
        "phpmetrics/phpmetrics": "^2.9",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-strict-rules": "^1.5",
        "phpunit/phpunit": "^10.5",
        "deptrac/deptrac": "^2.0",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Mihod\\PaymentGateway\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mihod\\PaymentGateway\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "test:coverage": "php -d xdebug.mode=coverage ./vendor/bin/phpunit --coverage-html coverage/html --coverage-text",
        "cs-check": "phpcs",
        "cs-check:summary": "phpcs --report=summary",
        "cs-check:full": "phpcs --report=full",
        "cs-check:source": "phpcs --report=source",
        "cs-check:info": "phpcs --report=info",
        "cs-check:diff": "phpcs --report=diff",
        "cs-check:xml": "mkdir -p var && phpcs --report=checkstyle --report-file=var/phpcs-checkstyle.xml",
        "cs-fix": "phpcbf",
        "analyse": "phpstan analyse --memory-limit=256M",
        "deptrac": "deptrac analyse",
        "phpmd": "phpmd src text phpmd.xml",
        "phpmd:xml": "mkdir -p var && phpmd src xml phpmd.xml --report-file var/phpmd-src.xml",
        "phpmd:tests": "phpmd tests text phpmd-tests.xml",
        "phpmd:tests:xml": "mkdir -p var && phpmd tests xml phpmd-tests.xml --report-file var/phpmd-tests.xml",
        "metrics": "mkdir -p var && phpmetrics --report-html=var/phpmetrics src",
        "quality": [
            "@cs-check",
            "@analyse",
            "@test",
            "@deptrac",
            "@phpmd",
            "@phpmd:tests"
        ],
        "quality:all": [
            "@quality",
            "@metrics"
        ],
        "setup:badssl": "bash scripts/fetch-badssl-certs.sh"
    }
}
